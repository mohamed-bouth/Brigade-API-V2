                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Catégorie créée avec succès"
                    },
                    "401": {
                        "description": "Utilisateur non authentifié"
                    },
                    "403": {
                        "description": "Accès refusé, réservé aux administrateurs"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
