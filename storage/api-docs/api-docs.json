                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "_method",
                                    "name"
                                ],
                                "properties": {
                                    "_method": {
                                        "description": "Astuce Laravel pour simuler la méthode PUT",
                                        "type": "string",
                                        "example": "PUT"
                                    },
                                    "name": {
                                        "description": "min:3 | max:64",
                                        "type": "string",
                                        "example": "Burgers M"
                                    },
                                    "description": {
                                        "description": "max:256",
                                        "type": "string",
                                        "example": "this pizzas isn't good anymore"
                                    },
                                    "image": {
                                        "description": "Nouvelle image optionnelle",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "color": {
                                        "description": "Champ optionnel pour aider le front-end",
                                        "type": "string",
                                        "example": "green"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Catégorie mise à jour avec succès"
                    },
                    "401": {
                        "description": "Utilisateur non authentifié"
                    },
                    "403": {
                        "description": "Accès refusé ou action non autorisée"
                    },
                    "404": {
                        "description": "Catégorie introuvable"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
