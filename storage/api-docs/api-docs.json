{
    "openapi": "3.0.0",
    "info": {
        "title": "API Brigade",
        "description": "Documentation complète de notre API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Authentification"
                ],
                "summary": "Créer un nouveau compte utilisateur",
                "operationId": "ed9e6359cd4d4c5a88a0988241ba91c2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Ahmed Ali"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "ahmed@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Utilisateur créé avec succès et token généré"
                    },
                    "422": {
                        "description": "Erreur de validation des données"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Authentification"
                ],
                "summary": "Se connecter pour obtenir un token",
                "operationId": "70c6b10de034cc4a99d7f27696d9bbdd",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "ahmed@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Connexion réussie et token généré"
                    },
                    "401": {
                        "description": "Email ou mot de passe incorrect"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Authentification"
                ],
                "summary": "Se déconnecter et révoquer le token actuel",
                "operationId": "4d4063453914462375352ca16dc69b81",
                "responses": {
                    "200": {
                        "description": "Déconnexion réussie"
                    },
                    "401": {
                        "description": "Non autorisé (Token manquant ou invalide)"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/categories": {
            "get": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Afficher la liste des catégories de l'utilisateur",
                "operationId": "24b2153f6bf0f1d06c91cdd8fb542198",
                "responses": {
                    "200": {
                        "description": "Liste des catégories récupérée"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Ajouter une nouvelle catégorie",
                "operationId": "91bbceda8562281ebd4ac193d27e973a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "name",
                                    "image"
                                ],
                                "properties": {
                                    "name": {
                                        "description": "min:3 | max:64",
                                        "type": "string",
                                        "example": "Pizzas"
                                    },
                                    "image": {
                                        "description": "Image de la catégorie (jpeg, png, jpg, webp)",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Catégorie créée avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/categories/{id}": {
            "get": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Afficher les détails d'une catégorie spécifique",
                "operationId": "bab3b8569b16a0c29590f93b515eb785",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID de la catégorie",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Détails de la catégorie récupérés"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Modifier une catégorie existante",
                "operationId": "cbf4800ab4c11f1a824259a93fbf4429",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID de la catégorie à modifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "_method",
                                    "name"
                                ],
                                "properties": {
                                    "_method": {
                                        "description": "Astuce Laravel (Obligatoire)",
                                        "type": "string",
                                        "example": "PUT"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Burgers M"
                                    },
                                    "image": {
                                        "description": "Nouvelle image (Optionnelle)",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Catégorie mise à jour avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Supprimer une catégorie",
                "operationId": "cef7dc8378165751a8eb0a40e342e8c1",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID de la catégorie à supprimer",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Catégorie supprimée avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/categories/{id}/plats": {
            "post": {
                "tags": [
                    "Catégories"
                ],
                "summary": "Affecter un plat à une catégorie",
                "operationId": "b18fd1461858dc85396ff37eda9718d4",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID de la catégorie",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "plat_id"
                                ],
                                "properties": {
                                    "plat_id": {
                                        "description": "L'ID du plat existant",
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Le plat a été ajouté à la catégorie avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/plats": {
            "get": {
                "tags": [
                    "Plats"
                ],
                "summary": "Afficher la liste des plats de l'utilisateur",
                "operationId": "7ee5af8650ad8f31e1889c9e119497f3",
                "responses": {
                    "200": {
                        "description": "Liste des plats récupérée avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Plats"
                ],
                "summary": "Ajouter un nouveau plat",
                "operationId": "2b82e29ebbfaeed88d135731f1c1b21e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "name",
                                    "description",
                                    "price",
                                    "image"
                                ],
                                "properties": {
                                    "name": {
                                        "description": "min:3 | max:64",
                                        "type": "string",
                                        "example": "Tacos Poulet"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Délicieux tacos avec frites et sauce algérienne"
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 45.5
                                    },
                                    "image": {
                                        "description": "Image du plat (jpeg, png, jpg, webp)",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Plat créé avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/plats/{id}": {
            "get": {
                "tags": [
                    "Plats"
                ],
                "summary": "Afficher les détails d'un plat spécifique",
                "operationId": "069d13f1b3679dd3fca366defacb9c36",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID du plat",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Détails du plat récupérés"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Plats"
                ],
                "summary": "Modifier un plat existant",
                "operationId": "74121d46fd948d2c0407953566bb624d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID du plat à modifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "_method",
                                    "name",
                                    "description",
                                    "price"
                                ],
                                "properties": {
                                    "_method": {
                                        "description": "Astuce Laravel pour forcer la méthode PUT",
                                        "type": "string",
                                        "example": "PUT"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Tacos Viande Hachée"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Modification de la description"
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 50
                                    },
                                    "image": {
                                        "description": "Nouvelle image (Optionnelle)",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Plat mis à jour avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Plats"
                ],
                "summary": "Supprimer un plat",
                "operationId": "cad66fe64c4242b08c362ec217becdcb",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID du plat à supprimer",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Plat supprimé avec succès"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Authentification",
            "description": "Authentification"
        },
        {
            "name": "Catégories",
            "description": "Catégories"
        },
        {
            "name": "Plats",
            "description": "Plats"
        }
    ]
}